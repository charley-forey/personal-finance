# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/personal_finance

# Redis
REDIS_URL=redis://localhost:6379

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
# Plaid (free ngrok: one tunnel only — point ngrok at port 3000, not 3001)
PLAID_WEBHOOK_URL=https://your-tunnel.example.com/webhooks/plaid
# Production OAuth banks need HTTPS. With ngrok on :3000 use:
# PLAID_REDIRECT_URI=https://your-tunnel.example.com/app
# Leave blank to skip OAuth redirect (works for most non-OAuth institutions).
PLAID_REDIRECT_URI=
PLAID_PRODUCTS=transactions,investments,liabilities
# Items linked with transactions-only cannot gain investments later — re-link those institutions.
# See docs/ops or Accounts page “Upgrade connection” banner.

# Encryption
TOKEN_ENCRYPTION_KEY=
# Required in production — unique per environment; rotating salt re-encrypts all tokens
TOKEN_ENCRYPTION_SALT=
# Soft-delete grace period before hard cascade (days). Set 0 for immediate delete.
ACCOUNT_DELETION_GRACE_DAYS=14
# Advisor portal kill switch (set false to 404 all /advisor/* routes)
ADVISOR_PORTAL_ENABLED=true

# WorkOS
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:3000/callback
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# OpenAI
OPENAI_API_KEY=

# Anthropic (fallback)
ANTHROPIC_API_KEY=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_FAMILY=
STRIPE_PRICE_ADVISOR=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_FAMILY=
NEXT_PUBLIC_STRIPE_PRICE_ADVISOR=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WORKOS_CLIENT_ID=
NEXT_PUBLIC_PLAID_ENV=production

# Object Storage (R2/S3)
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_BUCKET=finance-os-documents

# Feature flags
UNLEASH_URL=
UNLEASH_API_TOKEN=

# Kill switches (set to "false" to disable; see docs/ops/KILL-SWITCHES.md)
# AI_ENABLED=true
# PLAID_SYNC_ENABLED=true
# INTELLIGENCE_JOBS_ENABLED=true
# EVENT_PIPELINE_ENABLED=true
# SSE_ENABLED=true
# ADVISOR_PORTAL_ENABLED=true

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Platform admin (comma-separated emails — break-glass bootstrap + seed)
# Seeded DB owner: charley.s.forey@gmail.com
PLATFORM_ADMIN_EMAILS=charley.s.forey@gmail.com
