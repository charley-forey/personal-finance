{
  "name": "personal-finance",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@pf/web",
    "dev:api": "turbo run dev --filter=@pf/api",
    "dev:worker": "turbo run dev --filter=@pf/worker",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@pf/database",
    "db:migrate": "turbo run db:migrate --filter=@pf/database",
    "db:push": "turbo run db:push --filter=@pf/database",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20"
  }
}
